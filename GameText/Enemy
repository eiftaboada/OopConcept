abstract class Enemy {
    protected String name;
    private int hp;
    private int def;
    private int basicAttack;

    public Enemy(String name, int hp, int def, int basicAttack) {
        this.name = name;
        this.hp = hp;
        this.def = def;
        this.basicAttack = basicAttack;
    }

    public abstract int skill();
    public abstract void encounter();
    public abstract void victory();
    public abstract void defeat();

    public int getBasicAttack() {
        return basicAttack;
    }
}

class Boss extends Enemy {
    public Boss() {
        super("Boss", 100, 100, 10);
    }

    @Override
    public int skill() {
        System.out.println(name + " uses Technology to predict enemy moves.");
        return getBasicAttack() * 2;
    }

    @Override
    public void encounter() {
        System.out.println("I am boss, prepare to die");
    }

    @Override
    public void defeat() {
        System.out.println("I am defeated. Proceed to next world.");
    }

    @Override
    public void victory() {
        System.out.println("I am victorious. Go back to training");
    }
}

class Mobs extends Enemy {
    public Mobs(String name, int hp, int def) {
        super(name, hp, def, 10);
    }

    @Override
    public int skill() {
        System.out.println(name + " uses basic attack.");
        return getBasicAttack();
    }

    @Override
    public void encounter() {
        System.out.println("I am mob, defeat me before the boss");
    }

    @Override
    public void defeat() {
        System.out.println("I am defeated. Proceed to the boss.");
    }

    @Override
    public void victory() {
        System.out.println("I win. Loser");
    }
}
